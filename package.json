{
  "private": true,
  "name": "autogm-monorepo",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "dev:desktop": "turbo dev --filter=autogm-desktop",
    "dev:mobile": "turbo dev --filter=autogm-mobile",
    "dev:web": "turbo dev --filter=autogm-web",
    "pack:ci": "pnpm install --config.node-linker=hoisted && pnpm --filter autogm-desktop build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "heroku-prebuild": "corepack enable && corepack prepare pnpm@10.30.1 --activate",
    "heroku-postbuild": "pnpm install --frozen-lockfile && pnpm --filter @autogm/shared build && pnpm --filter autogm-web build"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.25.0"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "sharp",
      "core-js-pure",
      "electron-winstaller"
    ]
  },
  "version": "1.0.0"
}
