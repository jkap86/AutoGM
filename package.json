{
  "private": true,
  "name": "sleepier-monorepo",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "dev:desktop": "turbo dev --filter=sleepier-desktop",
    "dev:mobile": "turbo dev --filter=sleepier-mobile",
    "pack:ci": "pnpm install --config.node-linker=hoisted && pnpm --filter sleepier-desktop build"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "sharp",
      "core-js-pure",
      "electron-winstaller"
    ]
  }
}
