{
  "expo": {
    "name": "AutoGM",
    "slug": "autogm-mobile",
    "version": "1.0.0",
    "scheme": "autogm",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "bundleIdentifier": "com.jkap86.autogm",
      "appleTeamId": "FK8K2ZKZT5",
      "buildNumber": "9",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.jkap86.autogm",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3ab15deb-1643-4bfc-9686-165b91a6e5a1"
      }
    },
    "owner": "jkap86"
  }
}
