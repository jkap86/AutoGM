{
  "name": "autogm-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ app/",
    "eas-build-post-install": "cd ../.. && pnpm --filter @autogm/shared build",
    "build:ios": "eas build --platform ios --profile preview",
    "build:ios:prod": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios"
  },
  "dependencies": {
    "@autogm/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "~2.1.2",
    "expo": "~53.0.0",
    "expo-constants": "^17.1.8",
    "expo-linking": "^7.1.7",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.3",
    "expo-status-bar": "~2.2.3",
    "react": "^19.0.0",
    "react-native": "~0.79.6",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-webview": "~13.13.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.14",
    "metro-cache": "0.82.5",
    "typescript": "^5.8.3"
  }
}
