{
  "name": "autogm-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ app/",
    "eas-build-post-install": "cd ../.. && pnpm --filter @autogm/shared build",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:testflight": "eas build --platform ios --profile production",
    "submit:ios:testflight": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@autogm/shared": "workspace:*",
    "@expo/metro-runtime": "^55.0.10",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "expo": "~55.0.0",
    "expo-constants": "~55.0.15",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "react": "^19.2.0",
    "react-native": "~0.83.6",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "~13.16.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "typescript": "^5.9.3"
  }
}
